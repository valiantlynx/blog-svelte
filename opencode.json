{
	"$schema": "https://opencode.ai/config.json",
	"watcher": {
		"ignore": [
			"node_modules/**",
			"dist/**",
			".git/**",
			".svelte-kit/**",
			"pocketbase/pb_data/**",
			"project.inlang/cache/**",
			"src/lib/paraglide/**"
		]
	},
	"instructions": [
		"CONTRIBUTING.md",
		"docs/guidelines.md",
		".cursor/rules/*.md",
		".github/instructions/*.md",
		".github/copilot-instructions.md"
	],
	"provider": {
		"ollama": {
			"npm": "@ai-sdk/openai-compatible",
			"name": "Ollama",
			"options": {
				"baseURL": "http://192.168.38.157:9012/v1"
			},
			"models": {
				"qwen2.5:7b": {
					"name": "Qwen 2.5 7B"
				},
				"qwen3-embedding:0.6b": {
					"name": "Qwen3 Embedding 0.6B"
				},
				"qwen3-embedding:8b": {
					"name": "Qwen3 Embedding 8B"
				},
				"qwen3-vl:8b": {
					"name": "Qwen3 VL 8B"
				},
				"qwen3-vl:4b": {
					"name": "Qwen3 VL 4B"
				},
				"qwen3-vl:2b": {
					"name": "Qwen3 VL 2B"
				},
				"qwen2.5:72b": {
					"name": "Qwen 2.5 72B"
				},
				"mistral:7b": {
					"name": "Mistral 7B"
				},
				"llama3.2:3b": {
					"name": "Llama 3.2 3B"
				},
				"llama3.2:1b": {
					"name": "Llama 3.2 1B"
				},
				"qwen3-vl:32b": {
					"name": "Qwen3 VL 32B"
				},
				"deepseek-r1:70b": {
					"name": "DeepSeek R1 70B"
				},
				"qwen3-coder:30b": {
					"name": "Qwen3 Coder 30B"
				},
				"llama3.1:70b": {
					"name": "Llama 3.1 70B"
				},
				"qwen3:30b": {
					"name": "Qwen3 30B"
				},
				"gpt-oss:latest": {
					"name": "GPT OSS"
				},
				"llama3.1:latest": {
					"name": "Llama 3.1 8B"
				},
				"nomic-embed-text:latest": {
					"name": "Nomic Embed Text"
				},
				"gemma3:latest": {
					"name": "Gemma3 4B"
				},
				"devstral-small-2:latest": {
					"name": "Devstral Small 2"
				},
				"deepseek-ocr:latest": {
					"name": "DeepSeek OCR"
				},
				"glm-ocr:latest": {
					"name": "GLM OCR"
				},
				"qwen3.5:0.8b": {
					"name": "Qwen3.5 0.8B"
				},
				"qwen3.5:2b": {
					"name": "Qwen3.5 2B"
				},
				"qwen3.5:4b": {
					"name": "Qwen3.5 4B"
				},
				"qwen3.5:9b": {
					"name": "Qwen3.5 9B"
				},
				"qwen3.5:27b": {
					"name": "Qwen3.5 27B"
				},
				"qwen3.5:35b": {
					"name": "Qwen3.5 35B"
				},
				"glm-4.7-flash": {
					"name": "GLM 4.7 Flash"
				}
			}
		}
	},
	"model": "ollama/gpt-oss:latest",
	"small_model": "ollama/llama3.2:1b",
	"mcp": {
		"playwright": {
			"command": ["npx", "-y", "@playwright/mcp@latest"],
			"type": "local"
		},
		"svelte-mcp": {
			"type": "remote",
			"url": "https://mcp.svelte.dev/mcp"
		},
		"daisyui-blueprint": {
			"type": "local",
			"command": ["npx", "-y", "daisyui-blueprint@latest"],
			"environment": {
				"LICENSE": "",
				"EMAIL": ""
			}
		},
		"github": {
			"type": "remote",
			"headers": {"Authorization": "Bearer {env:GITHUB_PAT}"},
			"url": "https://api.githubcopilot.com/mcp/",
			"oauth": {
				"clientId": "{env:MADP_CLIENT_ID}",
				"clientSecret": "{env:MADP_CLIENT_SECRET}",
				"scope": "tools:read tools:execute"
			}
		}
	}
}
